# Resend (e-mail)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
FROM_EMAIL=contato@uvits.com.br
FROM_NAME=Uvits Pro Prescritor
TO_EMAIL=contato@uvits.com.br

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria_minimo_32_caracteres

# CORS — em produção: https://prescritores.uvits.com.br
ALLOWED_ORIGIN=https://prescritores.uvits.com.br

# Vercel Postgres — preenchido automaticamente ao criar o banco no Vercel
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
