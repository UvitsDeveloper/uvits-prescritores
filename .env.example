# Resend (e-mail)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
FROM_EMAIL=contato@uvits.com.br
FROM_NAME=Uvits Pro Prescritor
TO_EMAIL=contato@uvits.com.br

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria_minimo_32_caracteres

# CORS — em produção: https://prescritores.uvits.com.br
ALLOWED_ORIGIN=https://prescritores.uvits.com.br

# Vercel Postgres — preenchido automaticamente ao criar o banco no Vercel
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Upstash Redis (rate limiting durável) — preenchido automaticamente pela
# integração Upstash do Vercel Marketplace. Sem estas vars, o rate limit cai
# no fallback em memória (ok para dev, fraco em serverless sob carga).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Monitor de uso compartilhado do Upstash Redis (api/_usage.js) — MESMA convenção
# da API de Frete. Todos os projetos no MESMO Redis somam na chave cmdusage:AAAA-MM
# e alertam por e-mail (Resend) em 80% e 95% do limite. Inerte sem Redis/e-mail.
REDIS_COMMAND_LIMIT=500000                # limite mensal de comandos (Upstash free)
REDIS_CMDS_PER_REQUEST=3                   # comandos estimados por requisição
USAGE_PROJECT=uvits-prescritores           # nome deste projeto (aparece no alerta)
ALERT_EMAIL_TO=                            # destinatário do alerta (fallback: TO_EMAIL)
ALERT_EMAIL_FROM=                          # remetente verificado (fallback: FROM_EMAIL)
